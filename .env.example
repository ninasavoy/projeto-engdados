# =============================================================================
# .env.example — copie para .env e ajuste conforme sua máquina:  cp .env.example .env
#
# O docker-compose lê este arquivo para substituir variáveis (portas do host).
# As mesmas variáveis também são usadas ao rodar o pipeline/scripts DIRETO do host
# (python-dotenv). Dentro dos containers, o compose injeta os valores corretos
# (POSTGRES_HOST=postgres, etc.), então o que está aqui vale para o HOST.
# =============================================================================

# ── Portas publicadas no host ────────────────────────────────────────────────
# Mude se as portas padrão já estiverem em uso por outro projeto.
POSTGRES_HOST_PORT=5432            # primário (DW)         -> host
POSTGRES_REPLICA_HOST_PORT=5434   # read replica          -> host

# ── Conexão do pipeline/scripts/API ao rodar NO HOST ─────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432                 # = POSTGRES_HOST_PORT
POSTGRES_DB=prf_dw
POSTGRES_USER=prf
POSTGRES_PASSWORD=prf123

# Read replica (leituras analíticas / API)
POSTGRES_REPLICA_HOST=localhost
POSTGRES_REPLICA_PORT=5434         # = POSTGRES_REPLICA_HOST_PORT

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=prf
RABBITMQ_PASSWORD=prf123
RABBITMQ_QUEUE=prf_raw_data

# ── Observabilidade ──────────────────────────────────────────────────────────
PUSHGATEWAY_URL=localhost:9091                       # métricas (Prometheus Pushgateway)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317    # tracing (Jaeger OTLP gRPC)

# ── Ingestão ─────────────────────────────────────────────────────────────────
# Anos do datatran presentes em data/bronze/acidentes_<ano>.csv.
PRF_YEARS=2022
PRF_MAX_RECORDS=0                  # 0 = sem limite; >0 limita registros/arquivo (demo rápida)

# Dados da PRF (datatran). A PRF distribui os CSVs via página oficial
# (https://www.gov.br/prf/pt-br/acesso-a-informacao/dados-abertos/dados-abertos-acidentes).
# Baixe os anos desejados e coloque em data/bronze/acidentes_<ano>.csv
# (o repositório já inclui 2022). Para outros anos, adicione o arquivo e o ano em PRF_YEARS.
# Opcional: download automático por URL direta (se tiver links estáveis):
# PRF_URL_2022=
