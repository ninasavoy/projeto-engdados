{
  "uid": "prf-pipeline",
  "title": "PRF Pipeline",
  "tags": ["prf", "engenharia-dados"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Registros ingeridos (Bronze)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }, "overrides": [] },
      "targets": [ { "expr": "sum(prf_records_ingested_total)", "refId": "A" } ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Registros processados (Silver)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }, "overrides": [] },
      "targets": [ { "expr": "sum(prf_records_processed_total)", "refId": "A" } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Registros carregados (Gold)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short" }, "overrides": [] },
      "targets": [ { "expr": "sum(prf_records_loaded_gold_total)", "refId": "A" } ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Duração por etapa (s) — soma observada",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "targets": [ { "expr": "sum by (stage) (prf_stage_duration_seconds_sum)", "legendFormat": "{{stage}}", "refId": "A" } ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Erros do pipeline por etapa",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "expr": "sum by (stage) (prf_pipeline_errors_total)", "legendFormat": "{{stage}}", "refId": "A" } ]
    }
  ]
}
